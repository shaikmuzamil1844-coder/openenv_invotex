# ─── HuggingFace ─────────────────────────────────────────────────────────────
# Your HuggingFace API token (get from https://huggingface.co/settings/tokens)
# Create a token with WRITE access
HF_TOKEN=hf_your_token_here

# ─── LLM API ─────────────────────────────────────────────────────────────────
# OpenAI-compatible API key (can also re-use HF_TOKEN if using HF inference)
# inference.py will fall back to HF_TOKEN if OPENAI_API_KEY is not set
OPENAI_API_KEY=sk_your_openai_key_here

# LLM endpoint — change this if using a different provider (e.g. Together, Fireworks)
API_BASE_URL=https://api.openai.com/v1

# Model to use for evaluation
MODEL_NAME=gpt-4o-mini

# ─── Domain Selection ────────────────────────────────────────────────────────
# Which domain to run: email_triage | traffic_control | customer_support
DOMAIN=email_triage

# ─── Environment URL ─────────────────────────────────────────────────────────
# URL of your deployed HuggingFace Space
HF_SPACE_URL=https://muzamil1844-openenv-invotex.hf.space

# ─── Database (auto-set in Docker) ───────────────────────────────────────────
DATABASE_URL=sqlite:////tmp/env.db
